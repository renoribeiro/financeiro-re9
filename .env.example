# RE9 Finanças — variáveis de ambiente.
#
# No modo mock atual (dados em memória) NENHUMA destas é necessária para rodar.
# Elas são para as integrações reais do plano (docs/MELHORIAS-2026-07.md).
#
# NO DOKPLOY: não suba um arquivo .env. Configure estas variáveis pela UI do
# Dokploy (aba "Environment" da aplicação) — elas são injetadas no container em
# runtime. Localmente, copie este arquivo para `.env` e preencha o que precisar.

# --- Runtime do servidor (já definidos no Dockerfile; sobrescreva se precisar) ---
# HOST=0.0.0.0
# PORT=3000

# Supabase (A1/A2)
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp Evolution API (B2)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# SMTP (B2)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# Claude API — importador inteligente (B3)
ANTHROPIC_API_KEY=

# NFS-e SEFIN Fortaleza (B1)
SEFIN_ENDPOINT=
CERT_A1_ENCRYPTION_KEY=
